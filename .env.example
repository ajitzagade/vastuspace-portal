# Copy this to .env.local and fill in values

# ── Public URLs & subdomains ─────────────────────────────────────────────────
# Host used for project sites: https://{slug}.{ROOT_DOMAIN}
# Vercel example:
ROOT_DOMAIN=vastuspace-portal.vercel.app
NEXT_PUBLIC_ROOT_DOMAIN=vastuspace-portal.vercel.app
# Apex URL for middleware redirects (subdomain /dashboard → main site)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase (add when ready to connect real database) ────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-key

# ── Mapbox (for interactive maps on landing pages) ────────────────────────────
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token
