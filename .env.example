# Copy this to .env.local and fill in values

# ── Admin sign-in (/login → /dashboard) ─────────────────────────────────────
# Defaults: admin / admin — change in production
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin
# ADMIN_SESSION_SECRET=use-a-long-random-string-openssl-rand-hex-32

# ── Public URLs ──────────────────────────────────────────────────────────────
# Apex URL (used for /projects/{slug} links when not using custom subdomains)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Subdomains (optional): wildcards are NOT supported on *.vercel.app — only on a custom domain you add in Vercel
# NEXT_PUBLIC_USE_PROJECT_SUBDOMAINS=true
# ROOT_DOMAIN=yourdomain.com
# NEXT_PUBLIC_ROOT_DOMAIN=yourdomain.com

# ── Supabase (add when ready to connect real database) ────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-key

# ── Mapbox (for interactive maps on landing pages) ────────────────────────────
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token
